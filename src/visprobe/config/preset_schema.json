{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://visprobe.dev/schemas/preset.json",
  "title": "VisProbe Preset",
  "description": "Schema for VisProbe robustness testing preset configurations",
  "type": "object",
  "required": ["name", "description", "strategies", "property"],
  "properties": {
    "name": {
      "type": "string",
      "description": "Human-readable name of the preset",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "description": "Brief description of what this preset tests"
    },
    "threat_model": {
      "type": "string",
      "enum": ["environmental", "adversarial", "combined", "all"],
      "description": "The threat model this preset addresses"
    },
    "threat_model_description": {
      "type": "string",
      "description": "Detailed description of the threat model"
    },
    "novelty": {
      "type": "string",
      "description": "What makes this preset unique or important"
    },
    "strategies": {
      "type": "array",
      "description": "List of perturbation strategies to apply",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/strategy"
      }
    },
    "property": {
      "type": "string",
      "enum": ["label_constant", "topk_stability", "confidence_drop", "l2_distance"],
      "description": "The property to test (oracle)"
    },
    "search_budget": {
      "type": "integer",
      "minimum": 1,
      "description": "Maximum number of search queries"
    },
    "compute_cost": {
      "type": "string",
      "enum": ["low", "medium", "high", "very_high"],
      "description": "Expected computational cost"
    },
    "use_cases": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Example use cases for this preset"
    },
    "estimated_time": {
      "type": "string",
      "description": "Estimated time to run this preset"
    },
    "requires": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Required dependencies (e.g., adversarial-robustness-toolbox)"
    },
    "legacy": {
      "type": "boolean",
      "description": "Whether this is a legacy preset",
      "default": false
    },
    "migration_hint": {
      "type": "string",
      "description": "Suggestion for migrating from this legacy preset"
    },
    "critical_insight": {
      "type": "string",
      "description": "Key insight for interpreting results"
    },
    "outputs_threat_breakdown": {
      "type": "boolean",
      "description": "Whether to output per-threat-model scores",
      "default": false
    }
  },
  "definitions": {
    "strategy": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "description": "Strategy type identifier"
        },
        "name": {
          "type": "string",
          "description": "Optional custom name for this strategy instance"
        },
        "description": {
          "type": "string",
          "description": "Description of what this strategy does"
        },
        "category": {
          "type": "string",
          "enum": ["natural", "adversarial", "realistic_attack"],
          "description": "Category for grouping in comprehensive presets"
        },
        "min_level": {
          "type": "number",
          "description": "Minimum perturbation level"
        },
        "max_level": {
          "type": "number",
          "description": "Maximum perturbation level"
        },
        "level_range": {
          "type": "array",
          "items": {
            "type": "number"
          },
          "minItems": 2,
          "maxItems": 2,
          "description": "Range of perturbation levels [min, max]"
        },
        "kernel_size": {
          "type": "integer",
          "minimum": 1,
          "description": "Kernel size for blur operations"
        },
        "eps": {
          "type": "number",
          "minimum": 0,
          "description": "Epsilon for adversarial attacks"
        },
        "eps_step": {
          "type": "number",
          "minimum": 0,
          "description": "Step size for iterative attacks"
        },
        "max_iter": {
          "type": "integer",
          "minimum": 1,
          "description": "Maximum iterations for iterative attacks"
        },
        "angle": {
          "type": "number",
          "description": "Angle for motion blur or rotation"
        },
        "threat_scenario": {
          "type": "string",
          "description": "Description of the threat scenario"
        },
        "components": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/strategy_component"
          },
          "description": "Component strategies for compositional perturbations"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "type": { "const": "compositional" }
            }
          },
          "then": {
            "required": ["components"]
          }
        }
      ]
    },
    "strategy_component": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "description": "Component strategy type"
        },
        "level_range": {
          "type": "array",
          "items": {
            "type": "number"
          },
          "minItems": 2,
          "maxItems": 2,
          "description": "Range of perturbation levels [min, max]"
        },
        "eps": {
          "type": "number",
          "minimum": 0
        },
        "max_iter": {
          "type": "integer",
          "minimum": 1
        }
      }
    }
  }
}
